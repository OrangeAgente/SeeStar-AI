{
  "$comment": "Shared project permissions for seestar-mcp. Public repo — no experimental flags imposed on cloners (agent-teams is enabled in the maintainer's user settings, not here).",
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(uv sync)",
      "Bash(uv add:*)",
      "Bash(uv lock)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(sed:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git reset --hard:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  }
}
